{
  "expo": {
    "name": "Smart Checkout",
    "slug": "smart-checkout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#F8F9FC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartcheckout.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Smart Checkout needs camera access to scan product barcodes."
      }
    },
    "android": {
      "package": "com.smartcheckout.app",
      "adaptiveIcon": {
        "backgroundColor": "#F8F9FC"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Smart Checkout needs camera access to scan product barcodes."
        }
      ],
      "expo-asset"
    ]
  }
}
